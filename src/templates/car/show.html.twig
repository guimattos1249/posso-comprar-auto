{% extends 'base.html.twig' %}

{% block title %}Car{% endblock %}

{% block body %}
    <div class="form-header">
        <h1>{{car.model}}</h1>
        <a href="{{ path('app_car_index') }}"
        class="text-sky-400 hover:underline hover:text-sky-950 cursor-pointer">
            ← Back to list
        </a>
    </div>

    <div class="table-container" style="max-width: 640px; margin-left: auto; margin-right: auto;">
        <table class="car-table">
            <tbody>
                <tr class="table-row">
                    <th class="table-header">Id</th>
                    <td>{{ car.id }}</td>
                </tr>
                <tr class="table-row">
                    <th>Marca</th>
                    <td>{{ car.brand }}</td>
                </tr>
                <tr  class="table-row">
                    <th>Modelo</th>
                    <td>{{ car.model }}</td>
                </tr>
                <tr  class="table-row">
                    <th>Varsão</th>
                    <td>{{ car.version }}</td>
                </tr>
                <tr  class="table-row">
                    <th>Ano</th>
                    <td>{{ car.year }}</td>
                </tr>
                <tr  class="table-row">
                    <th>Preço na tabela FIPE</th>
                    <td>{{ car.fipePrice }}</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="footer-action-buttons">
        <a href="{{ path('app_car_edit', {'id': car.id}) }}" class="btn-edit">Edit</a>

        {{ include('car/_delete_form.html.twig') }}
    </div>
{% endblock %}
